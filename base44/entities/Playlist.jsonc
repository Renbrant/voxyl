{
  "name": "Playlist",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Playlist name"
    },
    "description": {
      "type": "string",
      "description": "Playlist description"
    },
    "creator_id": {
      "type": "string",
      "description": "User ID of creator"
    },
    "creator_name": {
      "type": "string",
      "description": "Display name of creator"
    },
    "creator_email": {
      "type": "string",
      "description": "Email of creator"
    },
    "creator_username": {
      "type": "string",
      "description": "Public username of creator"
    },
    "creator_hidden": {
      "type": "boolean",
      "default": false,
      "description": "Whether creator's profile is hidden"
    },
    "rss_feeds": {
      "type": "array",
      "description": "List of RSS feed URLs",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "image": {
            "type": "string"
          }
        }
      }
    },
    "visibility": {
      "type": "string",
      "enum": [
        "public",
        "private",
        "friends_only"
      ],
      "default": "public",
      "description": "Playlist visibility"
    },
    "max_duration": {
      "type": "number",
      "description": "Max episode duration in minutes (0 = no limit)"
    },
    "share_token": {
      "type": "string",
      "description": "Unique token for sharing"
    },
    "cover_image": {
      "type": "string",
      "description": "Cover image URL"
    },
    "likes_count": {
      "type": "number",
      "default": 0
    },
    "plays_count": {
      "type": "number",
      "default": 0
    },
    "reports_count": {
      "type": "number",
      "default": 0,
      "description": "Number of times this playlist has been reported"
    }
  },
  "required": [
    "name"
  ],
  "rls": {
    "create": {
      "data.creator_id": "{{user.id}}",
      "data.creator_email": "{{user.email}}"
    },
    "read": {},
    "update": {},
    "delete": {
      "data.creator_id": "{{user.id}}"
    }
  }
}